. tempfile analysis

. save `analysis'
file C:\Users\ANIL~1.SHR\AppData\Local\Temp\ST_501c_000002.tmp saved as .dta format

. 
. * Weighted Gini from the trapezoidal area under the Lorenz curve.
. capture program drop weighted_gini

. program define weighted_gini, rclass
  1.     syntax varname, Wvar(varname)
  2.     preserve
  3.         keep `varlist' `wvar'
  4.         drop if missing(`varlist', `wvar') | `wvar' <= 0
  5.         sort `varlist'
  6.         quietly generate double __wx = `wvar' * `varlist'
  7.         quietly summarize `wvar', meanonly
  8.         local W = r(sum)
  9.         quietly summarize __wx, meanonly
 10.         local Y = r(sum)
 11.         quietly generate double __L = sum(__wx) / `Y'
 12.         quietly generate double __L0 = __L[_n-1]
 13.         quietly replace __L0 = 0 in 1
 14.         quietly generate double __area2 = (__L + __L0) * (`wvar' / `W')
 15.         quietly summarize __area2, meanonly
 16.         return scalar gini = 1 - r(sum)
 17.         return scalar N = _N
 18.     restore
 19. end

. 
. tempname results_post

. tempfile results

. postfile `results_post' str24 section str48 group int display_order ///
>     long sample_households double households persons hc_household hc_individual gini ///
>     using `results', replace
(file C:\Users\ANIL~1.SHR\AppData\Local\Temp\ST_501c_000003.tmp not found)

. global NLSS_RESULTS_POST `results_post'

. 
. capture program drop post_estimate

. program define post_estimate
  1.     syntax, Section(string) Group(string) Order(integer) Condition(string)
  2.     preserve
  3.         quietly keep if `condition'
  4.         quietly count
  5.         local n = r(N)
  6.         quietly summarize hhs_wt, meanonly
  7.         local households = r(sum)
  8.         quietly summarize ind_wt, meanonly
  9.         local persons = r(sum)
 10.         quietly summarize poor [aw=hhs_wt], meanonly
 11.         local hc_hh = r(mean)
 12.         quietly summarize poor [aw=ind_wt], meanonly
 13.         local hc_ind = r(mean)
 14.         quietly weighted_gini pcep, wvar(ind_wt)
 15.         local gini = r(gini)
 16.         post $NLSS_RESULTS_POST ("`section'") ("`group'") (`order') (`n') ///
>             (`households') (`persons') (`hc_hh') (`hc_ind') (`gini')
 17.     restore
 18. end

. 
. use `analysis', clear
(NLSS04_DICT)

. post_estimate, section("National") group("Nepal") order(1) condition("1")

. 
. foreach u in 1 0 {
  2.     local ulab : label urban_lab `u'
  3.     local ord = cond(`u' == 1, 1, 2)
  4.     post_estimate, section("Urban/rural") group("`ulab'") order(`ord') condition("urban == `u'")
  5. }

. 
. foreach g in 1 2 {
  2.     local glab : label Q01_02_VS1 `g'
  3.     post_estimate, section("Head gender") group("`glab'") order(`g') condition("head_gender == `g'")
  4. }

. 
. levelsof domain, local(domains)
11 12 21 22 30 31 32 41 42 51 52 61 62 71 72

. local ord = 0

. foreach d of local domains {
  2.     local ++ord
  3.     local dlab : label domainlab `d'
  4.     post_estimate, section("Analytical domain") group("`dlab'") order(`ord') condition("domain == `d'")
  5. }

. postclose `results_post'

. macro drop NLSS_RESULTS_POST

. 
. use `results', clear

. sort section display_order

. format households persons %15.0fc

. format hc_household hc_individual gini %9.6f

. export delimited using "output/results/poverty_results.csv", replace
(file output/results/poverty_results.csv not found)
file output/results/poverty_results.csv saved

